SERVER_HOST=0.0.0.0
SERVER_PORT=3000
APP_ENV=development
# Same semantics as Express `NODE_ENV` for error JSON (prod hides non-operational details).
NODE_ENV=development
LOG_LEVEL=debug
HELLO_MESSAGE=Hello, World!
# SRV (Atlas default) — on some Macs DNS resolves *.mongodb.net.local and fails; use DATABASE_DIRECT instead.
DATABASE=mongodb+srv://user:<password>@cluster.example.net/?retryWrites=true&w=majority
# Standard URI from Atlas (Connect → Drivers) — avoids SRV / .local DNS issues
# DATABASE_DIRECT=mongodb://user:<password>@host1:27017,host2:27017/TravelAndTour?replicaSet=...
DATABASE_LOCAL=mongodb://127.0.0.1:27017/TravelAndTour
DATABASE_NAME=TravelAndTour
DATABASE_PASSWORD=your-db-password
JWT_SECRET=super-secret-key
JWT_EXPIRES_IN=90d
JWT_COOKIE_EXPIRES_IN=90
EMAIL_USERNAME=your-email-user
EMAIL_PASSWORD=your-email-password
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_FROM=noreply@TravelAndTour.dev
EMAIL_FROM_NAME=TravelAndTour
PUBLISH_URL=https://example.com
MAPBOX_ACCESS_TOKEN=pk.example.mapbox.token
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
FRONTEND_URL=https://localhost:5173
# Static files root (`public/`) — `/img/users/*` uploads, `/img/tours/*` tour photos
# PUBLIC_DIR=public
# USERS_UPLOAD_DIR=public/img/users
# TOURS_STATIC_DIR=public/img/tours
# Public API URL for Stripe product images (defaults to http://localhost:SERVER_PORT)
# SERVER_PUBLIC_URL=http://localhost:3000
